{
  "name": "portal-kiosk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "npm run migrate:local && echo 'Starting Wrangler dev mode...' && npm run build && npx wrangler dev",
    "dev:ui": "nuxt dev",
    "deploy": "npm run build && npx wrangler deploy",
    "migrate:local": "./scripts/run-migrations.sh",
    "migrate:remote": "./scripts/run-migrations.sh --remote",
    "preview": "npx wrangler dev",
    "postinstall": "nuxt prepare",
    "clean": "./scripts/clean-orders.sh"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.12.0",
    "nuxt": "^3.14.0",
    "typescript": "^5.6.0",
    "vue": "^3.5.0",
    "wrangler": "^4.64.0"
  }
}
